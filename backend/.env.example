# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_DB=internjobs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full database URL (optional - will be constructed from above if not provided)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/internjobs

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Authentication (JWT) Configuration
# =============================================================================
# IMPORTANT: auth_secret must be at least 32 characters for security
AUTH_SECRET=your_super_secret_auth_key_at_least_32_characters_long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# OAuth Token Encryption (RSA Keys)
# =============================================================================
# RSA keys for encrypting OAuth access tokens stored in the database.
# Generate keys using: python -c "from app.auth.crypto import generate_rsa_key_pair; print(generate_rsa_key_pair())"
# The public key is required for encryption, private key for decryption.
# For production, store these securely (e.g., secrets manager, not in .env)
OAUTH_ENCRYPTION_PUBLIC_KEY=
OAUTH_ENCRYPTION_PRIVATE_KEY=

# =============================================================================
# AI/Embedding Services
# =============================================================================

# Ollama (Local LLM)
# OLLAMA_BASE_URL is used for embeddings.
# OLLAMA_CLASSIFICATION_URL is optional and, if set, is used for job classification.
# If OLLAMA_CLASSIFICATION_URL is not set, classification falls back to OLLAMA_BASE_URL.
# For native Ollama single instance: OLLAMA_BASE_URL=http://localhost:11434
# For split instances: OLLAMA_BASE_URL=http://localhost:11435 and OLLAMA_CLASSIFICATION_URL=http://localhost:11434
# For LM Studio: EMBEDDING_PROVIDER=lmstudio, OLLAMA_BASE_URL=http://localhost:1234
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CLASSIFICATION_URL=

# =============================================================================
# Embedding Configuration
# =============================================================================
# Provider options: "ollama" (native Ollama API) or "lmstudio" (OpenAI-compatible)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# External API URLs (Public - can be left as defaults)
# =============================================================================
# These are public API endpoints and do not require authentication
GREENHOUSE_API_URL=https://boards-api.greenhouse.io/v1/boards
LEVER_API_URL=https://api.lever.co/v0/postings
SIMPLIFY_JOBS_INTERN_URL=https://raw.githubusercontent.com/SimplifyJobs/Summer2026-Internships/dev/README.md
SIMPLIFY_JOBS_NEW_GRAD_URL=https://raw.githubusercontent.com/SimplifyJobs/New-Grad-Positions/dev/README.md

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=InternNexus API
