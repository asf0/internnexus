# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_DB=internjobs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full database URL (optional - will be constructed from above if not provided)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/internjobs

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Authentication (JWT) Configuration
# =============================================================================
AUTH_SECRET=your_super_secret_auth_key_at_least_32_characters_long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# AI/Embedding Services
# =============================================================================

# Ollama (Local LLM) - for embeddings and visa classification
# For native Ollama: EMBEDDING_PROVIDER=ollama, OLLAMA_BASE_URL=http://localhost:11434
# For LM Studio: EMBEDDING_PROVIDER=lmstudio, OLLAMA_BASE_URL=http://localhost:1234
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Embedding Configuration
# =============================================================================
# Provider options: "ollama" (native Ollama API) or "lmstudio" (OpenAI-compatible)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# External API URLs (Public - can be left as defaults)
# =============================================================================
# These are public API endpoints and do not require authentication
GREENHOUSE_API_URL=https://boards-api.greenhouse.io/v1/boards
LEVER_API_URL=https://api.lever.co/v0/postings
SIMPLIFY_JOBS_INTERN_URL=https://raw.githubusercontent.com/SimplifyJobs/Summer2026-Internships/dev/README.md
SIMPLIFY_JOBS_NEW_GRAD_URL=https://raw.githubusercontent.com/SimplifyJobs/New-Grad-Positions/dev/README.md

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=InternNexus API
