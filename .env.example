# Database configuration (required)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=s
POSTGRES_HOST=
POSTGRES_PORT=

# AI provider configuration
# Uncomment OPENAI_CLASSIFICATION_URL only if classification should use a separate Ollama host.
OPENAI_BASE_URL=
OPENAI_CLASSIFICATION_URL=
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=2560
CLASSIFICATION_MODEL=
CLASSIFICATION_BATCH_SIZE=10

# Cloudflare tunnel token
CLOUDFLARED_TOKEN=

# Redis configuration (optional; leave empty for in-memory cache)
REDIS_URL=

# Authentication and secret configuration
AUTH_SECRET=

# OAuth credentials (Google and GitHub sign-in)
GH_CLIENT_ID=
GH_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API URLs
GREENHOUSE_API_URL=
LEVER_API_URL=
SIMPLIFY_JOBS_INTERN_URL=
SIMPLIFY_JOBS_NEW_GRAD_URL=

# Backend and frontend URLs
BACKEND_URL=

NEXTAUTH_URL=
AUTH_URL=
NEXT_PUBLIC_API_URL=

# CORS origins
CORS_ORIGINS=

# Proxy trust settings
# Set TRUST_PROXY_HEADERS=true only if traffic always comes through your proxy.
# Set TRUSTED_PROXY_IPS to a comma-separated list of IPs or CIDRs.
TRUST_PROXY_HEADERS=
TRUSTED_PROXY_IPS=

# OpenAI-compatible API example
OPENAI_BASE_URL=
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=2560
CLASSIFICATION_MODEL=
NEXTAUTH_URL=
AUTH_URL=
NEXT_PUBLIC_API_URL=

# OAuth encryption keys (Base64 encoded)
OAUTH_ENCRYPTION_PUBLIC_KEY_B64=
OAUTH_ENCRYPTION_PRIVATE_KEY_B64=

SEARXNG_SECRET=
