# Database configuration (required)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=

# AI provider configuration
# Uncomment OLLAMA_CLASSIFICATION_URL only if classification should use a separate Ollama host.
OLLAMA_BASE_URL=
OLLAMA_CLASSIFICATION_URL=
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
CLASSIFICATION_MODEL=
VISA_CLASSIFIER_MODEL=

# Cloudflare tunnel token
CLOUDFLARED_TOKEN=

# Redis configuration
REDIS_URL=

# Authentication and secret configuration
AUTH_SECRET=

# OAuth credentials (Google and GitHub sign-in)
GH_CLIENT_ID=
GH_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API URLs
GREENHOUSE_API_URL=
LEVER_API_URL=
SIMPLIFY_JOBS_INTERN_URL=
SIMPLIFY_JOBS_NEW_GRAD_URL=

# Backend and frontend URLs
BACKEND_URL=

NEXTAUTH_URL=
AUTH_URL=
NEXT_PUBLIC_API_URL=

# CORS origins
CORS_ORIGINS=

# Proxy trust settings
# Set TRUST_PROXY_HEADERS=true only if traffic always comes through your proxy.
# Set TRUSTED_PROXY_IPS to a comma-separated list of IPs or CIDRs.
TRUST_PROXY_HEADERS=
TRUSTED_PROXY_IPS=

# Local LM Studio example
OLLAMA_BASE_URL=
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
CLASSIFICATION_MODEL=
VISA_CLASSIFIER_MODEL=
NEXTAUTH_URL=
AUTH_URL=
NEXT_PUBLIC_API_URL=

# OAuth encryption keys (Base64 encoded)
OAUTH_ENCRYPTION_PUBLIC_KEY_B64=
OAUTH_ENCRYPTION_PRIVATE_KEY_B64=
