# Database (required)
POSTGRES_DB=internnexus
POSTGRES_USER=internnexus
POSTGRES_PASSWORD=change_me_in_production

# Ollama embedding configuration
OLLAMA_BASE_URL=http://192.168.0.70:11434
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b

# Visa classifier model
VISA_CLASSIFIER_MODEL=deepseek-r1-distill-qwen-14b

# Cloudflare tunnel token
CLOUDFLARED_TOKEN=

# Redis (for persistent rate limiting)
REDIS_URL=redis://localhost:6379/0

# Auth Secret (min 32 characters)
AUTH_SECRET=

# OAuth Credentials
GH_CLIENT_ID=
GH_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API URLs
GREENHOUSE_API_URL=https://boards-api.greenhouse.io/v1/boards
LEVER_API_URL=https://api.lever.co/v0/postings
SIMPLIFY_JOBS_INTERN_URL=https://raw.githubusercontent.com/SimplifyJobs/Summer2026-Internships/dev/README.md
SIMPLIFY_JOBS_NEW_GRAD_URL=https://raw.githubusercontent.com/SimplifyJobs/New-Grad-Positions/dev/README.md

# Frontend URLs
BACKEND_URL=http://localhost:8000
NEXTAUTH_URL=https://your-domain.com
AUTH_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_SHOW_JOB_COUNT=true

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# OAuth Encryption Keys (RSA PEM format, optional)
OAUTH_ENCRYPTION_PUBLIC_KEY=
OAUTH_ENCRYPTION_PRIVATE_KEY=
