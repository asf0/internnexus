#DATABASE CONFIGURATION (required)
POSTGRES_DB=your_database_name
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost    # or your database host/IP
POSTGRES_PORT=5432

#OLLAMA CONFIGURATION (Server)
OLLAMA_BASE_URL=http://localhost:port
EMBEDDING_PROVIDER=your_provider
EMBEDDING_MODEL=your_embedding_model
CLASSIFICATION_MODEL=your_classification_model

#VISA CLASSIFIER CONFIGURATION
VISA_CLASSIFIER_MODEL=your_visa_classifier_model

#CLOUDFLARE TOKEN
CLOUDFLARED_TOKEN=your_cloudflare_token

#REDIS CONFIGURATION (Persistent Rate Limiting)
REDIS_URL=redis://localhost:6379/0

#AUTHENTICATION & SECRET CONFIGURATION
AUTH_SECRET=your_auth_secret

#OAUTH CREDENTIALS (Google and GitHub sign‑in)
GH_CLIENT_ID=your_gh_client_id
GH_CLIENT_SECRET=your_gh_client_secret
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

#API URLs
GREENHOUSE_API_URL=https://boards-api.greenhouse.io/v1/boards
LEVER_API_URL=https://api.lever.co/v0/postings
SIMPLIFY_JOBS_INTERN_URL=https://raw.githubusercontent.com/SimplifyJobs/Summer2026-Internships/dev/README.md
SIMPLIFY_JOBS_NEW_GRAD_URL=https://raw.githubusercontent.com/SimplifyJobs/New-Grad-Positions/dev/README.md

#BACKEND & FRONTEND URLs
BACKEND_URL=http://localhost:8000

NEXTAUTH_URL=https://yourdomain.com
AUTH_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com
CORS ORIGINS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

#LOCAL TRAINING CONFIGURATION (uncomment to use)
OLLAMA_BASE_URL=http://localhost:1234
EMBEDDING_PROVIDER=lmstudio
EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b
CLASSIFICATION_MODEL=qwen2.5-3b-instruct
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

#OAUTH ENCRYPTION KEYS (Base64 encoded)
OAUTH_ENCRYPTION_PUBLIC_KEY_B64=your_oauth_encryption_public_key_base64 OAUTH_ENCRYPTION_PRIVATE_KEY_B64=your_oauth_encryption_private_key_base64